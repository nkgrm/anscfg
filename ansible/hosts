#ansible_host — реальный IP-адрес или имя хоста.
#ansible_port — нестандартный порт подключения SSH / WinRM.
#ansible_user — имя пользователя для подключения.
#ansible_password — пароль (не рекомендуется хранить в открытом виде).
#ansible_ssh_private_key_file — путь к приватному SSH-ключу.
#ansible_connection — тип соединения (ssh, winrm, local, docker)
#[webservers]
## Переменные для конкретного хоста
#web01.example.com ansible_port=2222 ansible_user=admin

#[webservers:vars]
## Переменные, общие для всей группы webservers
#ansible_connection=ssh
#env_type=production

[server]
redos  
[admin]
grimm ansible_connection=local #если пользователь находится локально, плейбук будет отрабатывать локально без подключения по ssh
